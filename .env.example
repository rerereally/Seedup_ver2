# Seedup Supabase Configuration
# Replace these with your actual Supabase Project details

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-only ingestion keys
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
NEXT_PUBLIC_SITE_URL=http://localhost:3001
GITHUB_TOKEN=github_pat_or_token
INGEST_SECRET=change-this-secret
ADMIN_EMAILS=you@example.com
NEXT_PUBLIC_ADMIN_EMAILS=you@example.com

# Email newsletter sender
RESEND_API_KEY=your-resend-api-key
NEWSLETTER_FROM_EMAIL=Seedup <newsletter@your-domain.com>

# Cloudflare deployment
# After deployment, set this to your workers.dev URL or custom domain.
# NEXT_PUBLIC_SITE_URL=https://seedup-ver2.your-subdomain.workers.dev

# Optional. Leave empty to use the default sources in lib/ingest/sources.ts.
# One source per line: name|url|language
# INGEST_RSS_SOURCES="IT동아|https://it.donga.com/feeds/rss/|ko
# 전자신문|http://rss.etnews.com/03.xml|ko
# 요즘IT|https://yozm.wishket.com/magazine/feed/|ko
# Lenny's Newsletter|https://www.lennysnewsletter.com/feed|en
# ZDNet Korea|https://zdnet.co.kr/feed/|ko"
# INGEST_PRODUCT_SOURCES="Product Hunt|https://www.producthunt.com/feed|en"
